@{
    Layout = null;
    var jobsList = ViewBag.JobsList as List<ResumeMatcher.Controllers.JobSpaceModel>;
    var resumesList = ViewBag.ResumesList as List<ResumeMatcher.Controllers.ResumeModel>;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Resumes Repository</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
            body {
                font-family: 'Inter', sans-serif;
                background: radial-gradient(circle at 10% 20%, #0f192d 0%, #050a19 100%) !important;
                color: #eef2ff !important;
                min-height: 100vh;
                padding: 30px 20px;
            }

            .glass-nav {
                background: rgba(255, 255, 255, 0.04);
                backdrop-filter: blur(16px);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 24px;
            }

            .glass-card {
                background: rgba(255, 255, 255, 0.03);
                backdrop-filter: blur(12px);
                border: 1px solid rgba(255, 255, 255, 0.08) !important;
                border-radius: 24px;
            }

            .form-control-custom, .form-select-custom {
                background: #070f21 !important;
                border: 1px solid rgba(255, 255, 255, 0.1) !important;
                color: white !important;
                border-radius: 14px;
                padding: 12px;
            }

            .btn-glow-success {
                background: linear-gradient(95deg, #059669 0%, #10b981 100%);
                border: none;
                padding: 14px 28px;
                border-radius: 16px;
                color: white;
                font-weight: 600;
                width: 100%;
                box-shadow: 0 10px 20px rgba(16,185,129,0.2);
            }

            .btn-outline-custom {
                border: 1px solid rgba(255, 255, 255, 0.2);
                color: #eef2ff;
                border-radius: 30px;
                padding: 8px 18px;
                text-decoration: none;
            }

            .skill-tag {
                background: rgba(16, 185, 129, 0.15);
                border: 1px solid rgba(16, 185, 129, 0.3);
                color: #34d399;
                padding: 4px 12px;
                border-radius: 10px;
                font-size: 0.8rem;
                display: inline-block;
                margin: 4px 4px 0 0;
            }

            .text-gradient {
                color: #ffffff;
            }
    </style>
</head>
<body>
    <div class="container" style="max-width: 1300px;">
        <div class="d-flex justify-content-between align-items-center mb-5 p-4 glass-nav">
            <div>
                <h1 class="fw-bold mb-0 text-gradient" style="font-size: 2.2rem;">AI ResumeMatch</h1>
                <p class="text-white-50 small mb-0 mt-1"><i class="fas fa-database text-success me-1"></i> Resumes Pipeline</p>
            </div>
            <div class="d-flex gap-2">
                <a href="/Home/Index" class="btn-outline-custom small"><i class="fas fa-home me-1"></i> Dashboard</a>
                <a href="/Home/Jobs" class="btn-outline-custom small"><i class="fas fa-briefcase me-1"></i> Jobs</a>
                <a href="/Home/Resumes" class="btn-outline-custom small"><i class="fas fa-database me-1"></i> Resumes</a>
                <a href="/Home/Match" class="btn-outline-custom small"><i class="fas fa-chart-pie me-1"></i> Reports</a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-5">
                <div class="glass-card p-4">
                    <h5 class="fw-bold mb-4"><i class="fas fa-file-upload text-success me-2"></i>Ingest New Resume</h5>
                    <form action="/Home/AddResume" method="post">
                        <div class="mb-3">
                            <label class="small text-white-50 mb-2">Candidate Name</label>
                            <input type="text" name="candidateName" class="form-control form-control-custom" placeholder="Suleman" required />
                        </div>
                        <div class="mb-3">
                            <label class="small text-white-50 mb-2">Email</label>
                            <input type="email" name="email" class="form-control form-control-custom" placeholder="suleman@example.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="small text-white-50 mb-2">Target Job (Dropdown Alignment)</label>
                            <select name="appliedJobId" class="form-select form-select-custom" required>
                                <option value="">-- Select Target Vector Job --</option>
                                @if (jobsList != null)
                                {
                                    foreach (var job in jobsList)
                                    {
                                        <option value="@job.Id">@job.Title</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="small text-white-50 mb-2">Skills (Comma Separated)</label>
                            <input type="text" name="skills" class="form-control form-control-custom" placeholder="e.g. C#, Docker" required />
                        </div>
                        <button type="submit" class="btn-glow-success"><i class="fas fa-cog me-2"></i>Parse &amp; Auto-Calculate Score</button>
                    </form>
                </div>
            </div>

            <div class="col-md-7">
                <div class="glass-card p-4">
                    <h4 class="fw-bold mb-4"><i class="fas fa-file-invoice me-2 text-primary"></i>Active Candidates Pipeline</h4>
                    <div class="d-flex flex-column gap-3">
                        @if (resumesList != null)
                        {
                            foreach (var resume in resumesList)
                            {
                                <div class="p-3 rounded-4 mb-1" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h5 class="fw-bold text-white mb-1">@resume.CandidateName</h5>
                                            <p class="small text-white-50 mb-1"><i class="fas fa-envelope me-1 text-muted"></i>@resume.Email</p>
                                            <span class="badge bg-secondary bg-opacity-20 text-info mb-3 d-inline-block small">Applied: @resume.AppliedJobTitle</span>
                                            <div>
                                                @if (resume.ExtractedSkills != null)
                                                {
                                                    foreach (var skill in resume.ExtractedSkills)
                                                    {
                                                        <span class="skill-tag">@skill</span>
                                                    }
                                                }
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <span class="small text-white-50 d-block mb-1">Auto Score</span>
                                            <h3 class="fw-bold text-success mb-0">@resume.MatchScore%</h3>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>