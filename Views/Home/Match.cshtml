@{
    Layout = null;
    var resumesList = ViewBag.ResumesList as List<ResumeMatcher.Controllers.ResumeModel>;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Dynamic Alignment Reports</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
            body {
                font-family: 'Inter', sans-serif;
                background: radial-gradient(circle at 10% 20%, #0f192d 0%, #050a19 100%) !important;
                color: #eef2ff !important;
                min-height: 100vh;
                padding: 30px 20px;
            }

            .glass-nav {
                background: rgba(255, 255, 255, 0.04);
                backdrop-filter: blur(16px);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 24px;
            }

            .glass-card {
                background: rgba(255, 255, 255, 0.03);
                backdrop-filter: blur(12px);
                border: 1px solid rgba(255, 255, 255, 0.08) !important;
                border-radius: 24px;
                padding: 25px;
                box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            }

            .form-select-custom {
                background: #070f21 !important;
                border: 1px solid rgba(255, 255, 255, 0.1) !important;
                color: white !important;
                border-radius: 14px;
                padding: 12px;
            }

            .btn-outline-custom {
                border: 1px solid rgba(255, 255, 255, 0.2);
                color: #eef2ff;
                border-radius: 30px;
                padding: 8px 18px;
                text-decoration: none;
            }

            .score-circle {
                width: 140px;
                height: 140px;
                border-radius: 50%;
                background: rgba(255,255,255,0.02);
                border: 4px solid #7c3aed;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2rem;
                font-weight: 700;
                color: #fff;
                box-shadow: 0 0 20px rgba(124,58,237,0.3);
                margin: 0 auto;
            }

            .text-gradient {
                color: #ffffff;
            }
    </style>
</head>
<body>
    <div class="container" style="max-width: 1200px;">
        <div class="d-flex justify-content-between align-items-center mb-5 p-4 glass-nav">
            <div>
                <h1 class="fw-bold mb-0 text-gradient" style="font-size: 2.2rem;">AI ResumeMatch</h1>
                <p class="text-white-50 small mb-0 mt-1"><i class="fas fa-chart-pie text-info me-1"></i> Vector Alignment Audit Matrix</p>
            </div>
            <div class="d-flex gap-2">
                <a href="/Home/Index" class="btn-outline-custom small"><i class="fas fa-home me-1"></i> Dashboard</a>
                <a href="/Home/Jobs" class="btn-outline-custom small"><i class="fas fa-briefcase me-1"></i> Jobs</a>
                <a href="/Home/Resumes" class="btn-outline-custom small"><i class="fas fa-database me-1"></i> Resumes</a>
                <a href="/Home/Match" class="btn-outline-custom small"><i class="fas fa-chart-pie me-1"></i> Reports</a>
            </div>
        </div>

        <div class="glass-card mb-4">
            <label class="fw-bold mb-2 text-white-50"><i class="fas fa-user-check me-2 text-primary"></i>Select Candidate to Generate AI Matching Audit</label>
            <select id="resumeSelector" class="form-select form-select-custom" onchange="loadCandidateReport()">
                <option value="">-- Choose Candidate from active pipeline --</option>
                @if (resumesList != null)
                {
                    foreach (var resume in resumesList)
                    {
                        <option value="@resume.Id">@resume.CandidateName (Target: @resume.AppliedJobTitle)</option>
                    }
                }
            </select>
        </div>

        <div id="reportContainer" class="row g-4" style="display: none;">
            <div class="col-md-5 text-center">
                <div class="glass-card h-100 d-flex flex-column justify-content-center">
                    <h5 class="text-white-50 small mb-4">Live Target Scoring Index</h5>
                    <div class="score-circle mb-3" id="uiScore">0%</div>
                    <h4 class="fw-bold mt-2 text-white" id="uiCandidateName">Candidate Name</h4>
                    <p class="small text-info" id="uiJobTitle">Target Job</p>

                    <div class="mt-4" style="max-height: 220px;">
                        <canvas id="radarChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="glass-card h-100">
                    <h5 class="fw-bold mb-3 text-white"><i class="fas fa-brain text-purple me-2" style="color: #a855f7;"></i>Dynamic Vector Reasoning Log</h5>
                    <div class="p-3 rounded-4 mb-4" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); font-size: 0.95rem; line-height: 1.6; color: #cbd5e1;" id="uiReasoning">
                        Select a client vector to trace systemic alignment variables...
                    </div>

                    <h6 class="fw-bold mb-2 text-white-50">Feature Metric Assessment</h6>
                    <div class="progress mb-3" style="height: 12px; background: rgba(255,255,255,0.05); border-radius: 20px;">
                        <div class="progress-bar bg-info" id="uiProgressBar" style="width: 0%; border-radius: 20px;"></div>
                    </div>
                    <div class="d-flex justify-content-between small text-white-50">
                        <span>Core Stack Alignment</span>
                        <span id="uiProgressLabel">0% Checked</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let matchingChart = null;

        function loadCandidateReport() {
        const id = document.getElementById("resumeSelector").value;
        if (!id) {
        document.getElementById("reportContainer").style.display = "none";
        return;
        }

        fetch("/Home/GetReportData?resumeId=" + encodeURIComponent(id))
        .then(res => res.json())
        .then(data => {
        if (data.success) {
        document.getElementById("reportContainer").style.display = "flex";
        document.getElementById("uiScore").innerText = data.score + "%";
        document.getElementById("uiCandidateName").innerText = data.candidateName;
        document.getElementById("uiJobTitle").innerText = "Applied for: " + data.jobTitle;
        document.getElementById("uiReasoning").innerText = data.reasoning;

        document.getElementById("uiProgressBar").style.width = data.score + "%";
        document.getElementById("uiProgressLabel").innerText = data.score + "% Verified Match";

        const ctx = document.getElementById('radarChart').getContext('2d');
        if (matchingChart) { matchingChart.destroy(); }

        matchingChart = new Chart(ctx, {
        type: 'radar',
        data: {
        labels: ['Syntax Alignment', 'Architecture Execution', 'Domain Experience'],
        datasets: [{
        label: 'Skill Matrix Match',
        data: data.chartData,
        backgroundColor: 'rgba(124, 58, 237, 0.2)',
        borderColor: '#a855f7',
        pointBackgroundColor: '#10b981'
        }]
        },
        options: {
        scales: { r: { grid: { color: 'rgba(255,255,255,0.05)' }, angleLines: { color: 'rgba(255,255,255,0.05)' }, ticks: { display: false }, min: 0, max: 100 } },
        plugins: { legend: { display: false } }
        }
        });
        }
        });
        }
    </script>
</body>
</html>