@model ResumeMatcher.Models.Job
@{
    ViewData["Title"] = "Add Job";
}

<div style="max-width:720px;margin:0 auto;">
    <div class="page-title">Add New Job</div>
    <div class="page-subtitle">Nai job position create karo matching ke liye</div>

    <div class="glass-card p-5">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-5">
                    <div class="form-group">
                        <label class="form-label">Job Title *</label>
                        <input asp-for="Title" class="form-control" placeholder="Senior .NET Developer" />
                        <span asp-validation-for="Title" class="text-red text-sm"></span>
                    </div>
                </div>
                <div class="col-5">
                    <div class="form-group">
                        <label class="form-label">Company *</label>
                        <input asp-for="Company" class="form-control" placeholder="Tech Corp Pvt Ltd" />
                        <span asp-validation-for="Company" class="text-red text-sm"></span>
                    </div>
                </div>
                <div class="col-5">
                    <div class="form-group">
                        <label class="form-label">Location</label>
                        <input asp-for="Location" class="form-control" placeholder="Karachi, Pakistan" />
                    </div>
                </div>
                <div class="col-5">
                    <div class="form-group">
                        <label class="form-label">Experience Required</label>
                        <input asp-for="RequiredExperience" class="form-control" placeholder="3-5 years" />
                    </div>
                </div>
                <div class="col-full">
                    <div class="form-group">
                        <label class="form-label">Job Description *</label>
                        <textarea asp-for="Description" class="form-control" placeholder="Job description yahan likhein..."></textarea>
                        <span asp-validation-for="Description" class="text-red text-sm"></span>
                    </div>
                </div>
                <div class="col-full">
                    <div class="form-group">
                        <label class="form-label">Required Skills (comma se alag karo)</label>
                        <input asp-for="RequiredSkills" class="form-control"
                               placeholder="C#, .NET 8, Docker, SQL Server, Redis"
                               oninput="updateChips(this.value)" />
                        <div id="chipPreview" style="margin-top:10px;"></div>
                    </div>
                </div>
            </div>
            <div class="flex gap-3 mt-3">
                <button type="submit" class="btn btn-success" style="flex:1;justify-content:center;padding:13px;">
                    <i class="fas fa-save"></i> Save Job
                </button>
                <a asp-action="Index" class="btn btn-outline" style="padding:13px 24px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function updateChips(val) {
            var chips = val.split(',').map(function(s){ return s.trim(); }).filter(function(s){ return s; });
            document.getElementById('chipPreview').innerHTML =
                chips.map(function(s){ return '<span class="chip chip-purple">' + s + '</span>'; }).join('');
        }
    </script>
}