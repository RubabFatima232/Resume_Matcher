<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] • AI Resume Matcher 3D</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,500;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <script type="importmap">
            {
                "imports": {
                    "three": "https://unpkg.com/three@0.128.0/build/three.module.js"
                }
            }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/vanilla-tilt@1.8.0/dist/vanilla-tilt.min.js"></script>

    <style>
        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        }

        body {
        font-family: 'Inter', sans-serif;
        background: radial-gradient(circle at 10% 20%, rgba(15, 25, 45, 1) 0%, rgba(5, 10, 25, 1) 100%);
        color: #eef2ff;
        padding: 30px 20px;
        min-height: 100vh;
        }

        /* Glassmorphism Styles */
        .glass {
        background: rgba(15, 25, 45, 0.55);
        backdrop-filter: blur(12px);
        border-radius: 32px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.4);
        transition: all 0.3s ease;
        }

        .glass-card {
        background: rgba(20, 30, 55, 0.5);
        backdrop-filter: blur(12px);
        border-radius: 28px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition: transform 0.2s, box-shadow 0.2s;
        }

        .glass-card:hover {
        border-color: rgba(99, 102, 241, 0.6);
        box-shadow: 0 20px 35px -10px rgba(79, 70, 229, 0.3);
        }

        .tilt-3d {
        transform-style: preserve-3d;
        transition: all 0.1s ease;
        }

        .btn-glow {
        background: linear-gradient(95deg, #4f46e5 0%, #7c3aed 100%);
        border: none;
        padding: 10px 24px;
        border-radius: 40px;
        font-weight: 600;
        color: white;
        box-shadow: 0 0 12px rgba(79, 70, 229, 0.5);
        transition: 0.2s;
        text-decoration: none;
        }

        .btn-glow:hover {
        transform: scale(1.02);
        box-shadow: 0 0 20px rgba(79, 70, 229, 0.8);
        color: white;
        }

        #radar-container {
        width: 100%;
        height: 320px;
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        }

        .skill-chip {
        background: rgba(255,255,240,0.1);
        border-radius: 40px;
        padding: 6px 14px;
        font-size: 0.8rem;
        backdrop-filter: blur(4px);
        cursor: grab;
        transition: 0.1s;
        }

        .skill-chip.drag-over {
        background: #4f46e5;
        color: white;
        }

        .toast-notify {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 999;
        background: rgba(0,0,0,0.8);
        backdrop-filter: blur(12px);
        border-left: 4px solid #4f46e5;
        padding: 12px 20px;
        border-radius: 20px;
        font-size: 0.9rem;
        display: none;
        }

        .progress-3d {
        height: 8px;
        background: rgba(255,255,255,0.2);
        border-radius: 10px;
        overflow: hidden;
        }

        .progress-fill {
        width: 0%;
        height: 100%;
        background: linear-gradient(90deg, #4f46e5, #a855f7);
        border-radius: 10px;
        transition: width 0.5s;
        }
    </style>
</head>
<body>
    <div class="container" style="max-width: 1400px; margin: 0 auto;">
        <div class="d-flex justify-content-between align-items-center mb-4 glass p-3 rounded-4">
            <div>
                <h1 class="fw-bold" style="background: linear-gradient(135deg, #fff, #a78bfa); -webkit-background-clip: text; background-clip: text; color: transparent; margin-bottom: 0;">
                    <a href="/Home/Index" style="text-decoration: none; color: inherit;">AI ResumeMatch <span style="font-size:1rem;">✨ 3D Intelligence</span></a>
                </h1>
                <p class="text-white-50 small mb-0">Explainable AI • Glass UI • Real‑time matching</p>
            </div>
            <div class="d-flex gap-3">
                <a href="/Home/Jobs" class="btn btn-outline-light btn-sm rounded-pill"><i class="fas fa-briefcase"></i> Jobs</a>
                <a href="/Home/Resumes" class="btn btn-outline-light btn-sm rounded-pill"><i class="fas fa-database"></i> Resumes Library</a>
                <a href="/Home/Match" class="btn btn-outline-light btn-sm rounded-pill"><i class="fas fa-chart-pie"></i> Match Report</a>
                <i class="fas fa-cube fa-2x ms-2" style="color:#a78bfa;"></i>
            </div>
        </div>

        @RenderBody()
    </div>

    <div id="toastMsg" class="toast-notify"><i class="fas fa-bell"></i> <span id="toastText">Notification Alert!</span></div>

    <script>
        window.addEventListener('DOMContentLoaded', () => {
        VanillaTilt.init(document.querySelectorAll(".tilt-3d"), {
        max: 8,
        speed: 400,
        glare: true,
        "max-glare": 0.3,
        });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>