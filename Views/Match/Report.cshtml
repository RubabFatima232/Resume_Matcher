@model ResumeMatcher.ViewModels.MatchReportViewModel
@{
    ViewData["Title"] = "Match Report";
}

@{
    var score = Model.Result.MatchScore;
    var scoreColor = score >= 70 ? "#10b981" : score >= 50 ? "#f59e0b" : "#ef4444";
    var recBadge = Model.Result.Recommendation switch
    {
        "Highly Recommended" => "badge-green",
        "Recommended" => "badge-purple",
        "Maybe" => "badge-yellow",
        _ => "badge-red"
    };
    double circumference = 2 * 3.14159 * 70;
    double dashOffset = circumference * (1 - score / 100);
}

<div class="page-title mb-4">Match Report</div>

<div class="row">
    <div class="col-4">
        <div class="glass-card p-4" data-tilt data-tilt-max="5" style="text-align:center;">
            <svg width="180" height="180" viewBox="0 0 180 180" style="display:block;margin:0 auto 16px;">
                <circle cx="90" cy="90" r="70" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="14" />
                <circle cx="90" cy="90" r="70" fill="none"
                        stroke="@scoreColor" stroke-width="14"
                        stroke-dasharray="@circumference.ToString("F2")"
                        stroke-dashoffset="@circumference.ToString("F2")"
                        stroke-linecap="round"
                        transform="rotate(-90 90 90)"
                        id="scoreCircle"
                        style="transition:stroke-dashoffset 1.5s ease;filter:drop-shadow(0 0 8px @scoreColor);" />
                <text x="90" y="84" text-anchor="middle" font-size="30" font-weight="900" fill="@scoreColor">@score.ToString("F0")</text>
                <text x="90" y="105" text-anchor="middle" font-size="12" fill="rgba(255,255,255,0.38)">Match Score</text>
            </svg>

            <span class="badge @recBadge" style="font-size:0.88rem;padding:8px 20px;">
                @Model.Result.Recommendation
            </span>

            <div style="margin-top:20px;display:flex;flex-direction:column;gap:10px;">
                <div style="background:rgba(255,255,255,0.04);border-radius:12px;padding:14px;text-align:left;">
                    <div class="text-xs text-muted mb-1">CANDIDATE</div>
                    <div class="font-bold">@Model.Resume.CandidateName</div>
                    <div class="text-sm text-muted">@Model.Resume.FileName</div>
                </div>
                <div style="background:rgba(255,255,255,0.04);border-radius:12px;padding:14px;text-align:left;">
                    <div class="text-xs text-muted mb-1">POSITION</div>
                    <div class="font-bold">@Model.Job.Title</div>
                    <div class="text-sm text-muted">@Model.Job.Company</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6" style="display:flex;flex-direction:column;gap:16px;">

        <div class="glass-card p-4">
            <div class="font-bold mb-3"><i class="fas fa-brain text-purple"></i> AI Analysis</div>
            <div class="ai-box">@Model.Result.AISummary</div>
        </div>

        <div class="row" style="margin:0;">
            <div class="col-5" style="padding-left:0;">
                <div class="glass-card p-4">
                    <div class="font-bold text-green mb-2"><i class="fas fa-check-circle"></i> Matched Skills</div>
                    @if (Model.MatchedSkillsList.Any())
                    {
                        @foreach (var s in Model.MatchedSkillsList)
                        {
                            <span class="chip chip-green">@s</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted text-sm">Koi nahi</span>
                    }
                </div>
            </div>
            <div class="col-5" style="padding-right:0;">
                <div class="glass-card p-4">
                    <div class="font-bold text-red mb-2"><i class="fas fa-times-circle"></i> Missing Skills</div>
                    @if (Model.MissingSkillsList.Any())
                    {
                        @foreach (var s in Model.MissingSkillsList)
                        {
                            <span class="chip chip-red">@s</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted text-sm">Sab present! 🎉</span>
                    }
                </div>
            </div>
        </div>

        <div class="glass-card p-4">
            <div class="font-bold mb-3"><i class="fas fa-chart-bar text-purple"></i> Score Breakdown</div>
            <div class="flex-between mb-2 text-sm">
                <span>Overall Match</span>
                <span class="font-bold" style="color:@scoreColor;">@score.ToString("F0")%</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" id="scoreBar" style="width:0%;background:@scoreColor;"></div>
            </div>
            <div class="text-muted text-sm mt-2">
                <i class="fas fa-calendar"></i> @Model.Result.AnalyzedAt.ToString("MMM dd, yyyy • HH:mm")
            </div>
        </div>

        <div class="flex gap-3">
            <a asp-controller="Match" asp-action="Index" class="btn btn-violet">
                <i class="fas fa-redo"></i> New Analysis
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline">
                <i class="fas fa-home"></i> Dashboard
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(function() {
            document.getElementById('scoreBar').style.width = '@score.ToString("F0")%';
            var circle = document.getElementById('scoreCircle');
            if (circle) circle.style.strokeDashoffset = '@dashOffset.ToString("F2")';
        }, 400);
    </script>
}